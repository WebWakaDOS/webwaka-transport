{
  "compilerOptions": {
    // Environment — Cloudflare Workers + Vite bundler
    // "Bundler" moduleResolution matches Vite's resolution semantics
    // and eliminates false-positive TS2835 errors about .js extensions
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],

    // Cloudflare Workers types
    "types": ["@cloudflare/workers-types"],

    // Output
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // JSX (React 19)
    "jsx": "react-jsx",

    // Strict mode — non-negotiable
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "moduleDetection": "force",
    "noUncheckedSideEffectImports": true,

    // Paths — packages/core is resolved via Vite alias in tests and build
    // tsconfig paths ensure IDE and tsc see the same resolution
    "paths": {
      "@webwaka/core": ["./packages/core/src/index.ts"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "playwright"
  ]
}
