{
  "name": "webwaka-transport",
  "version": "1.0.0",
  "type": "module",
  "main": "src/worker.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && echo 'TypeCheck passed'",
    "deploy": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "build:ui": "vite build",
    "dev:ui": "vite",
    "preview:ui": "vite preview",
    "test:components": "vitest run --config vitest.config.browser.ts",
    "test:components:watch": "vitest --config vitest.config.browser.ts",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright test --reporter=html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebWakaDOS/webwaka-transport.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/WebWakaDOS/webwaka-transport/issues"
  },
  "homepage": "https://github.com/WebWakaDOS/webwaka-transport#readme",
  "description": "WebWaka Transport Suite — TRN-1 Seat Inventory, TRN-2 Agent Sales, TRN-3 Booking Portal, TRN-4 Operator Management",
  "dependencies": {
    "@webwaka/core": "file:packages/core",
    "dexie": "^4.3.0",
    "hono": "^4.12.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.9",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^3.2.4",
    "wrangler": "^4.76.0"
  }
}
